# Copy to .env.weyne on the VPS (never commit the real file).
#
#   cp .env.weyne.example .env.weyne && $EDITOR .env.weyne

# Release image tag — the full git SHA the publish workflow tagged, or "latest".
IMAGE_TAG=latest

# Cloudflare *tunnel* token for the dedicated `weyne` tunnel:
#   Cloudflare Zero Trust → Networks → Tunnels → weyne → Install → copy token.
# This is NOT the account API token.
CLOUDFLARE_TUNNEL_TOKEN=
