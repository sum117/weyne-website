# Weyne Representações — static file server behind Cloudflare.
#
# Cloudflare terminates TLS and proxies here over the tunnel, so this listens
# on plain HTTP :80. Security headers are set here for defense in depth
# (Cloudflare adds its own at the edge).
:80 {
	root * /srv
	encode zstd gzip
	file_server

	# Content-hashed Vite build assets — immutable, cache for a year.
	@immutable path /assets/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# HTML — always revalidate so contact/copy changes roll out immediately.
	@html path / *.html
	header @html Cache-Control "public, max-age=0, must-revalidate"

	# Other static (images, favicons, og, manifest, sitemap) — one-day cache.
	@static path /images/* /og/* *.png *.jpg *.jpeg *.webp *.avif *.svg *.ico *.webmanifest *.xml *.txt
	header @static Cache-Control "public, max-age=86400"

	# Baseline security headers on every response.
	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	log {
		output stdout
		format console
	}
}
